ANTHROPIC_API_KEY=sk-ant-...

# WSL path to your Coral config (run `whoami` in WSL to fill in username)
CORAL_CONFIG_DIR=/home/ubuntu/coral-hackathon

# GitHub fine-grained PAT (scopes: Contents + Pull requests read, optionally write for demo seeder)
GITHUB_TOKEN=
GITHUB_DEMO_REPO=<your-username>/coral-beacon-demo

# PagerDuty developer account API key (NOT read-only — seeder needs write)
PAGERDUTY_API_KEY=

# Datadog (us5 site — use api.us5.datadoghq.com, not api.datadoghq.com)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=us5.datadoghq.com

# StatusGator free plan API key
STATUSGATOR_API_KEY=
