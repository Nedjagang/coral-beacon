ANTHROPIC_API_KEY=sk-ant-...

# LLM backend: mock (free, instant), haiku (cheap ~$0.05/run), sonnet (default, demo quality)
LLM_MODE=haiku

# WSL path to your Coral config (run `whoami` in WSL to fill in username)
CORAL_CONFIG_DIR=/home/ubuntu/coral-hackathon

# GitHub fine-grained PAT (scopes: Contents + Pull requests read, optionally write for demo seeder)
GITHUB_TOKEN=
GITHUB_DEMO_REPO=<your-username>/coral-beacon-demo

# PagerDuty developer account API key — Coral reads PAGERDUTY_API_TOKEN
PAGERDUTY_API_TOKEN=

# Datadog — Coral reads DD_API_KEY, DD_APPLICATION_KEY, DD_SITE
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=us5.datadoghq.com

# StatusGator free plan — Coral reads STATUSGATOR_API_TOKEN
STATUSGATOR_API_TOKEN=
