# Coral Beacon — environment variables
# Copy to .env and fill in all values before running.

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# LLM backend: mock (free/instant) | haiku (~$0.05/run) | sonnet (~$0.20/run)
LLM_MODE=haiku

# Coral transport: subprocess (default, ASCII table) | mcp (JSON-RPC stdio)
CORAL_TRANSPORT=subprocess

# Path to your Coral config directory (created by `coral source add` commands)
CORAL_CONFIG_DIR=/home/ubuntu/coral-hackathon

# GitHub fine-grained PAT — scopes: Contents (read), Pull Requests (read)
GITHUB_TOKEN=github_pat_...

# PagerDuty REST API v2 key (https://developer.pagerduty.com)
PAGERDUTY_API_TOKEN=

# Datadog API + Application keys (https://app.datadoghq.com/organization-settings/api-keys)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=us5.datadoghq.com

# StatusGator API token (https://statusgator.com/account)
STATUSGATOR_API_TOKEN=
